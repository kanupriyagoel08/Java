import java.util.*;

public class Main {
    public static void main(String[] args) {

        List<Integer> list = Arrays.asList(1, 2, 3, 4, 5, 6, 7);

        int productOdd = list.stream()
                             .filter(n -> n % 2 != 0)
                             .reduce(1, (a, b) -> a * b);

        System.out.println("Product of odd numbers = " + productOdd);
    }
}
